# Observability — set true to enable request profiling, nested spans, and metrics
DEBUG_PROFILING=false
# Client-side TanStack Query cache logs (mirrors DEBUG_PROFILING in dev)
NEXT_PUBLIC_DEBUG_PROFILING=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (place enrichment on detail view)
GEMINI_API_KEY=your-gemini-api-key

# Google Maps Platform — Place Photos (New) for collection place images
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: protect import endpoint
IMPORT_SECRET=

# App URL — OAuth redirects + CDN fallback for R2 images
NEXT_PUBLIC_APP_URL=http://localhost:3000

# R2 public assets URL (custom domain or r2.dev public bucket URL)
# Example: https://assets.yourdomain.com  or  https://pub-xxxx.r2.dev
# If unset, images are served via /cdn/* from the Worker (reads ASSETS_BUCKET)
NEXT_PUBLIC_ASSETS_BASE_URL=

ENRICH_SAVE_THRESHOLD=1
ENRICH_POPULARITY_THRESHOLD=1
SEARCH_LOCAL_MIN_HITS=3
SEARCH_GOOGLE_ENABLED=true
SEARCH_SUGGEST_RATE_LIMIT_PER_MIN=30
SEARCH_AUTOCOMPLETE_CACHE_TTL_MIN=30
# Optional — override Google Places API pricing & monthly free tiers (Studio search dashboard)
# GOOGLE_FREE_AUTOCOMPLETE_SESSIONS=10000
# GOOGLE_FREE_PLACE_DETAILS=10000
# GOOGLE_FREE_PLACE_PHOTOS=1000
# SEARCH_COST_GOOGLE_AUTOCOMPLETE=0.00283
# SEARCH_COST_GOOGLE_PLACE_DETAILS=0.005
# SEARCH_COST_GOOGLE_TEXT_SEARCH=0.032
# SEARCH_COST_GOOGLE_PLACE_PHOTO=0.007
# SEARCH_COST_GEMINI_ENRICHMENT=0.0005
# Create token: Cloudflare dashboard → R2 → Manage API tokens → Object Read & Write
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional; defaults to random-sidequest-assets
# R2_BUCKET_NAME=random-sidequest-assets
