# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (place enrichment on detail view)
GEMINI_API_KEY=your-gemini-api-key

# Google Maps Platform — Place Photos (New) for collection place images
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: protect import endpoint
IMPORT_SECRET=

# App URL — used for OAuth redirects (must match Supabase Auth redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
